# Normalizar finales de línea: los scripts se ejecutan en Linux, así que
# SIEMPRE deben guardarse con finales Unix (LF), aunque se editen en Windows.
*.sh   text eol=lf
*.bash text eol=lf

# Ficheros de configuración que también corren en Linux
*.yml  text eol=lf
*.yaml text eol=lf
*.conf text eol=lf

# Dejar que Git detecte el resto automáticamente
* text=auto
